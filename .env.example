# ─────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# Discord application ID (same page — General Information → Application ID)
APPLICATION_ID=your-application-id-here

# ─────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# LOG_LEVEL=INFO

# Override shard count (default: auto-detected by Discord)
# SHARD_COUNT=1

# Path to Netscape-format cookies file for age-restricted / geo-locked content
# YTDL_COOKIEFILE=/app/cookies.txt

# Extra FFmpeg input options (default reconnect flags are built-in)
# FFMPEG_BEFORE_OPTIONS=

# Extra FFmpeg output options
# FFMPEG_OPTIONS=
